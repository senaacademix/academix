// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]

  role String? // "admin", "teacher", "student"

  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?
  icon       String?


  // Relations
  enrollments           Enrollment[]
  profile               Profile?
  attendances           Attendance[]
  remarks               Remark[]
  remarksCreated        Remark[]               @relation("TeacherRemarks")
  sharedContentCreated  SharedContent[]        @relation("TeacherSharedContent")
  programs              Program[]              @relation("ProgramTeachers")
  availabilityLocked     Boolean                @default(false)
  qualifiedCoursesLocked Boolean                @default(false)
  availabilities         TeacherAvailability[]
  groupsTaught          Group[]                @relation("GroupTeachers")
  qualifiedCourses      Course[]               @relation("TeacherQualifiedCourses")
  coursesTaught         Course[]               @relation("CourseTeacher")
  studentGrades         StudentGrade[]
  studentImprovementPlans ImprovementPlan[]    @relation("StudentImprovementPlans")
  teacherImprovementPlans ImprovementPlan[]    @relation("TeacherImprovementPlans")

  groupId                     String?
  group                       Group?            @relation(fields: [groupId], references: [id], onDelete: Cascade)

  availabilityLastModifiedById String?
  availabilityLastModifiedBy   User?            @relation("AvailabilityModifier", fields: [availabilityLastModifiedById], references: [id], onDelete: SetNull)
  availabilityUpdatedAt        DateTime?

  qualificationsLastModifiedById String?
  qualificationsLastModifiedBy   User?          @relation("QualificationsModifier", fields: [qualificationsLastModifiedById], references: [id], onDelete: SetNull)
  qualificationsUpdatedAt        DateTime?

  // Relations for when this user acts as a modifier for someone else
  availabilityModified         User[]           @relation("AvailabilityModifier")
  qualificationsModified       User[]           @relation("QualificationsModifier")

  workGroupsCreated            CourseWorkGroup[] @relation("TeacherWorkGroups")
  workGroups                   CourseWorkGroup[] @relation("StudentWorkGroups")
  studentAccessLogs            StudentAccessLog[]

  @@unique([email])
  @@map("user")
}

model Profile {
  id                        String    @id @default(cuid())
  identificacion            String
  nombres                   String
  apellido                  String
  telefono                  String?
  userId                    String    @unique
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  dataProcessingConsent     Boolean   @default(false)
  dataProcessingConsentDate DateTime?

  @@map("profile")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Course {
  id                   String    @id @default(cuid())
  title                String
  description          String?
  externalUrl          String? // Optional external course URL (e.g., Google Classroom, Moodle)
  icon                 String?
  usePercentageWeights Boolean   @default(true)
  weeklyHours          Float?    @default(0)
  badge                String?
  badgeColor           String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  enrollments        Enrollment[]
  attendances        Attendance[]
  remarks            Remark[]
  schedules          CourseSchedule[]
  sharedContent      SharedContent[]
  activities         Activity[]
  gradeCategories    GradeCategory[]
  gradeGroups        GradeGroup[]
  qualifiedTeachers  User[]            @relation("TeacherQualifiedCourses")
  teacherId          String?
  teacher            User?             @relation("CourseTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  order                Int       @default(0)
  periodId           String?
  period             Period?   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  groupId            String?
  group              Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  workGroups         CourseWorkGroup[]

  @@map("course")
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  status    EnrollmentStatus @default(APPROVED)

  @@unique([userId, courseId])
  @@map("enrollment")
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE_EARLY
}

model Attendance {
  id               String           @id @default(cuid())
  date             DateTime
  status           AttendanceStatus @default(ABSENT)
  arrivalTime      DateTime?
  departureTime    DateTime?
  justification    String?
  justificationUrl String?
  courseId         String
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([courseId, userId, date])
  @@map("attendance")
}

enum RemarkType {
  ATTENTION
  COMMENDATION
  CITATION
  OTHER
}

model Remark {
  id          String     @id @default(cuid())
  type        RemarkType
  title       String
  description String
  date        DateTime   @default(now())
  courseId    String
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User       @relation("TeacherRemarks", fields: [teacherId], references: [id], onDelete: Cascade)
  viewedAt    DateTime?  // When the student first opened the remark detail
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("remark")
}


enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model CourseSchedule {
  id        String    @id @default(cuid())
  courseId  String
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dayOfWeek DayOfWeek
  startTime String // Format: "HH:mm" (e.g., "08:00")
  endTime   String // Format: "HH:mm" (e.g., "10:00")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("course_schedule")
}

enum ScheduleEventType {
  HOLIDAY
  EVENT
}

model ScheduleEvent {
  id          String            @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  startTime   String?
  endTime     String?
  type        ScheduleEventType @default(HOLIDAY)
  externalUrl String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("schedule_event")
}

model SystemSettings {
  id                    String           @id @default("settings")
  institutionName       String?
  institutionLogo       String?
  siteTitle             String?
  siteLogo              String?
  socialLinks           String?          @default("[]")
  defaultTheme          String?          @default("default")
  defaultAppearance     String?          @default("system")
  defaultCodeTheme      String?          @default("one-dark-pro")
  forceDefaultSettings  Boolean          @default(false)
  institutionHeroImage  String?

  encryptedGithubToken  String?
  footerText            String?
  
  // App Visual Identity (Global)
  appThemeMode                String            @default("STUDENT") // "STUDENT", "LIGHT", "DARK"
  appThemeColor               String?           @default("zinc")
  appAllowThemeColorChange    Boolean           @default(true)
  appCodeTheme                String            @default("one-dark-pro")
  appAllowCodeThemeChange     Boolean           @default(true)

  // Schedules Draft/Published
  schedulesPublished          Boolean           @default(false)
  scheduleTitle               String?           @default("Horario Académico")
  scheduleStartDate           DateTime?
  scheduleEndDate             DateTime?
  maxTeacherHours             Int               @default(40)
  studentDailyLimit           Int               @default(2)
  limitAttendanceToCurrentWeek Boolean           @default(false)
  
  updatedAt             DateTime         @updatedAt

  @@map("system_settings")
}

model StudentAccessLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // Formato "YYYY-MM-DD"
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("student_access_log")
}



model SharedContent {
  id          String   @id @default(cuid())
  title       String
  description String?
  links       Json     @default("[]") // [{ label: string, url: string }]
  files       Json     @default("[]") // [{ name: string, content: string, language: string }]
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User     @relation("TeacherSharedContent", fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("shared_content")
}


model GradeCategory {
  id        String       @id @default(cuid())
  name      String       // Label like "Primer Corte", "Segundo Corte"
  weight    Float        @default(1.0) // Weight for final course grade (0-100)
  courseId  String
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  groups    GradeGroup[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("grade_category")
}

model GradeGroup {
  id          String           @id @default(cuid())
  name        String           // Label like "Talleres", "Exámenes"
  weight      Float            @default(1.0) // Weight for category grade (0-100)
  categoryId  String?
  category    GradeCategory?    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  courseId    String // Kept for legacy/convenience
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  items       GradeGroupItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("grade_group")
}

model GradeGroupItem {
  id                  String             @id @default(cuid())
  groupId             String
  group               GradeGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)

  weight              Float              @default(1.0) // Internal weight within the group
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("grade_group_item")
}

model Program {
  id              String     @id @default(cuid())
  name            String
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  scheduleTitle   String?
  maxTeacherHours Int        @default(40)
  periods         Period[]
  groups          Group[]
  teachers        User[]     @relation("ProgramTeachers")
  environments    TrainingEnvironment[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("program")
}

model Period {
  id          String     @id @default(cuid())
  name        String
  description String?
  order       Int        @default(0)
  programId   String
  program     Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  courses     Course[]
  groups      Group[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("period")
}

model Group {
  id          String     @id @default(cuid())
  name        String
  description String?
  programId   String
  program     Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  students    User[]
  teachers    User[]     @relation("GroupTeachers")
  courses     Course[]
  startDate   DateTime?
  endDate     DateTime?
  startTime   String     @default("08:00")
  endTime     String     @default("12:00")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  periodId    String?
  period      Period?    @relation(fields: [periodId], references: [id], onDelete: Cascade)

  environmentId String?
  environment   TrainingEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@map("group")
}

model TeacherAvailability {
  id          String    @id @default(cuid())
  teacherId   String
  teacher     User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek   DayOfWeek
  startTime   String    // Format: "HH:mm" (e.g., "08:00")
  endTime     String    // Format: "HH:mm" (e.g., "14:00")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([teacherId, dayOfWeek, startTime, endTime])
  @@map("teacher_availability")
}

model CourseWorkGroup {
  id        String   @id @default(cuid())
  name      String
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User     @relation("TeacherWorkGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  students  User[]   @relation("StudentWorkGroups")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_work_group")
}

model TrainingEnvironment {
  id          String   @id @default(cuid())
  name        String
  capacity    Int
  location    String?
  resources   String[] // e.g. ["Proyector", "Computadores", "Tablero digital"]
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  groups      Group[]

  programId   String?
  program     Program?  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("training_environment")
}

model Activity {
  id                  String   @id @default(cuid())
  title               String
  description         String?
  weight              Float    // Porcentaje de peso (ej. 20 para 20%)
  date                DateTime @default(now())
  allowSubmissionLink Boolean  @default(false)
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  grades      StudentGrade[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("activity")
}

model StudentGrade {
  id             String   @id @default(cuid())
  score          Float    // Nota de 0 a 5
  feedback       String?
  submissionLink String?  // Enlace de entrega enviado por el estudiante
  
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([activityId, userId])
  @@map("student_grade")
}

model AttendancePermissionRequest {
  id          String   @id @default(cuid())
  courseId    String
  teacherId   String
  date        DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("attendance_permission_request")
}

model RemarkTemplate {
  id          String     @id @default(cuid())
  type        RemarkType @default(ATTENTION)
  title       String
  description String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("remark_template")
}

model ImprovementPlan {
  id            String    @id @default(cuid())
  planNumber    String    // Número del plan de mejoramiento
  teacherDocUrl        String?   // Paso 1: Enlace al documento del plan (subido por profesor)
  signedDocUrl         String?   // Paso 2: Enlace al documento firmado (subido por estudiante)
  teacherSignedDocUrl  String?   // Paso 3: Contrafirma del profesor (enlace subido por profesor)
  startDate            DateTime
  endDate              DateTime
  observations         String?   // Observaciones
  
  // Relations
  studentId     String
  student       User      @relation("StudentImprovementPlans", fields: [studentId], references: [id], onDelete: Cascade)
  
  teacherId     String
  teacher       User      @relation("TeacherImprovementPlans", fields: [teacherId], references: [id], onDelete: Cascade)

  // Status
  viewedAt      DateTime? // Fecha de revisión por el estudiante
  
  // Evaluation
  planScore     Float?    // Calificación del plan (0-5)
  finalGrade    Float?    // Nota final (0-5)
  evidenceUrl   String?   // Enlace a la evidencia de evaluación (subido por profesor)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("improvement_plan")
}



